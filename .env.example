# =============================================================================
# FinSight — Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores marcados com <PREENCHER>
#   3. NUNCA commite o arquivo .env no Git (já está no .gitignore)
#
# SEGURANÇA: Trate chaves de API como senhas. Não compartilhe.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL — Banco de dados principal do projeto
# -----------------------------------------------------------------------------
# Credenciais do banco de dados do FinSight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight123
POSTGRES_DB=finsight
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# String de conexão completa (usada nos scripts Python)
# Formato: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://finsight:finsight123@localhost:5432/finsight


# -----------------------------------------------------------------------------
# APIs de Dados Financeiros
# -----------------------------------------------------------------------------

# Groq — GRÁTIS, sem cartão, Llama 3.3 70B (RECOMENDADO)
# Cadastre-se em: https://console.groq.com
GROQ_API_KEY=<PREENCHER>

# Google Gemini — opcional (1500 req/dia grátis)
# Cadastre-se em: https://aistudio.google.com/apikey
GEMINI_API_KEY=<PREENCHER_SE_USAR_GEMINI>

# OpenAI (gpt-4o-mini, etc.) — opcional
# Cadastre-se em: https://platform.openai.com/api-keys
OPENAI_API_KEY=<PREENCHER_SE_USAR_OPENAI>

# Anthropic (Claude) — opcional
# Cadastre-se em: https://console.anthropic.com/
ANTHROPIC_API_KEY=<PREENCHER_SE_USAR_ANTHROPIC>

# Qual LLM usar no RAG: "groq" | "gemini" | "openai" | "anthropic"
LLM_PROVIDER=groq

# Modelo específico
# Groq:      llama-3.3-70b-versatile  (grátis, rápido, excelente)
# Gemini:    gemini-2.0-flash-lite    (grátis, 1500 req/dia)
# OpenAI:    gpt-4o-mini
# Anthropic: claude-3-5-haiku-20241022
LLM_MODEL=llama-3.3-70b-versatile


# -----------------------------------------------------------------------------
# Configurações do Pipeline
# -----------------------------------------------------------------------------

# Tickers a monitorar (separados por vírgula, sem espaço)
#
# Formato yfinance:
#   Ações BR → terminam em .SA   (ex: PETR4.SA)
#   Ações US → sem sufixo        (ex: NKE, NU)
#   Adidas (Frankfurt) → ADDYY (ADR americano)
#
# Carteira configurada:
#   BR: PETR4 (Petrobras), VALE3 (Vale), ITUB4 (Itaú),
#       BBAS3 (Banco do Brasil), VIVT3 (Vivo/Telefônica)
#   US: NU (Nubank NYSE), NKE (Nike), ADDYY (Adidas ADR)
STOCK_TICKERS=PETR4.SA,VALE3.SA,ITUB4.SA,BBAS3.SA,VIVT3.SA,NU,NKE,ADDYY

# Quantos dias de histórico carregar na primeira ingestão
INITIAL_LOOKBACK_DAYS=90

# Configurações de chunking para o RAG
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K_RESULTS=5

# Modelo de embedding (roda localmente, sem custo)
# Opções: all-MiniLM-L6-v2 (leve) | all-mpnet-base-v2 (melhor qualidade)
EMBEDDING_MODEL=all-MiniLM-L6-v2
